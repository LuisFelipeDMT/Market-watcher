# ---- Data source ----------------------------------------------------------
# Which offer source the tracker pulls from: "mock" (default, no creds needed)
# or "xp" (scrapes the XP web platform; requires the credentials below).
OFFER_SOURCE=mock

# XP web platform credentials (only used when OFFER_SOURCE=xp).
# These are YOUR personal investor credentials. Keep this file private.
XP_USERNAME=
XP_PASSWORD=
# Some XP logins require the CPF and/or a TOTP/2FA secret.
XP_CPF=
XP_TOTP_SECRET=
# Page to scrape current holdings from (for FGC / diversification sizing).
XP_POSITIONS_URL=https://www.xpi.com.br/conta-corrente/extrato/

# ---- Tracker --------------------------------------------------------------
# How often (seconds) the tracker refreshes the offer list.
REFRESH_INTERVAL_SECONDS=10
# Reference data (rates/curves) refreshes on a slower cadence (seconds).
MARKET_REFRESH_SECONDS=300

# Minimum opportunity score (0-100) for an offer to be flagged/highlighted.
OPPORTUNITY_THRESHOLD=70

# ---- Market data ----------------------------------------------------------
# Where reference rates/curves come from: "auto" (live with fixtures fallback),
# "live", or "fixtures" (offline snapshot).
MARKET_SOURCE=auto
# Minimum cheapness (offered YTM - fair reference, in bps) for a secondary
# offer to earn its cheapness bonus.
MIN_CHEAPNESS_BPS=30
# Macro/duration penalty weight (higher => penalize long duration more).
MACRO_PENALTY_WEIGHT=1.0

# ---- FGC + diversification ------------------------------------------------
FGC_PER_INSTITUTION=250000
FGC_GLOBAL_4Y=1000000
# Non-FGC concentration caps as a fraction of total portfolio value.
MAX_ISSUER_CONCENTRATION=0.05
MAX_SECTOR_CONCENTRATION=0.20
# Assumed investable capital when no portfolio is loaded (BRL).
DEFAULT_PORTFOLIO_VALUE=100000

# ---- Market assumptions (fallback when live data is unavailable) ----------
# Annual percentages used when MARKET_SOURCE can't reach the live feeds.
CDI_ANNUAL=10.65
SELIC_ANNUAL=10.75
IPCA_ANNUAL=4.50

# ---- Equities (renda variável: stocks + FIIs) -----------------------------
# Equity universe source: "fixtures" (offline, default) or "brapi" (live,
# free quotes/fundamentals from brapi.dev with a per-ticker fixtures fallback).
EQUITY_SOURCE=fixtures
BRAPI_BASE_URL=https://brapi.dev/api
# Optional brapi.dev token (raises the free rate limit). Keep this file private.
BRAPI_TOKEN=
# Where the persisted per-ticker watch state (WATCH/ARMED/TRIGGERED) lives.
EQUITY_WATCHLIST_PATH=data/equity_watchlist.json

# Valuation: discount rate = Selic + this equity risk premium (fraction).
EQUITY_RISK_PREMIUM=0.05
# Base margin of safety demanded before arming a name (fraction of fair value).
STOCK_BASE_MOS=0.15
FII_BASE_MOS=0.08
# MoS macro tightening: extra MoS per point of Selic above the neutral level.
MOS_NEUTRAL_SELIC=8.0
MOS_MACRO_FACTOR=1.0
# FII valuation anchors (dividend yield and price-to-NAV for fair value).
FII_TARGET_DY=0.085
FII_TARGET_PVP=1.0
# Stage gates: min quality to stay in the pipeline; entry score to trigger.
EQUITY_QUALITY_MIN=55
EQUITY_ENTRY_MIN=50

# ---- Alerts ---------------------------------------------------------------
# Notify when a renda fixa offer becomes an opportunity or an equity enters
# the buy zone (TRIGGERED). Alerts are always kept in memory (/alerts) and
# logged; set a webhook to also push them out.
ALERTS_ENABLED=true
# Generic JSON webhook (Slack/Discord/Telegram-compatible). Leave blank to skip.
ALERT_WEBHOOK_URL=
# Only alert above this opportunity score (0 = everything flagged).
ALERT_MIN_SCORE=0
# How many recent alerts to keep in memory for the /alerts endpoint.
ALERT_HISTORY_SIZE=100

# ---- Server ---------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
